PORT=3000
APP_URL=https://your-domain.com
CHECKOUT_URL=https://your-checkout-link.com
CRON_SECRET=replace-with-a-long-random-secret
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret
FORCE_HTTPS=true

# Web Push (required for push reminders)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
